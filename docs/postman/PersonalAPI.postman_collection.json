{
  "info": {
    "_postman_id": "e8b5c3f4-9a64-4d59-b623-2c8f8a2d7f0a",
    "name": "PersonalAPI - Production Grade",
    "description": "Comprehensive Postman collection for currently implemented PersonalAPI endpoints. Includes auth automation, reusable variables, and response assertions for regression-safe API verification.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.collectionVariables.get('baseUrl')) {",
          "  pm.collectionVariables.set('baseUrl', 'http://localhost:8000');",
          "}",
          "if (!pm.collectionVariables.get('apiPrefix')) {",
          "  pm.collectionVariables.set('apiPrefix', '/v1');",
          "}",
          "pm.request.headers.upsert({ key: 'Accept', value: 'application/json' });"
        ]
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8000", "type": "string" },
    { "key": "apiPrefix", "value": "/v1", "type": "string" },
    { "key": "email", "value": "qa.user@example.com", "type": "string" },
    { "key": "password", "value": "ChangeMe123!", "type": "string" },
    { "key": "fullName", "value": "QA User", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "apiKeyId", "value": "", "type": "string" },
    { "key": "developerApiKey", "value": "", "type": "string" },
    { "key": "searchQuery", "value": "meeting notes", "type": "string" },
    { "key": "typeFilter", "value": "document", "type": "string" },
    { "key": "limit", "value": "20", "type": "string" },
    { "key": "offset", "value": "0", "type": "string" }
  ],
  "item": [
    {
      "name": "Platform",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            },
            "description": "Liveness endpoint for container health probes and smoke checks."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "var body = pm.response.json();",
                  "pm.test('Health payload is valid', function () {",
                  "  pm.expect(body).to.have.property('status');",
                  "  pm.expect(body.status).to.eql('ok');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"full_name\": \"{{fullName}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            },
            "description": "Creates a new user account. May return 409 if the user already exists."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201 or 409', function () {",
                  "  pm.expect([201, 409]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Authenticates a user and captures the access token into collection variables."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "var body = pm.response.json();",
                  "pm.test('Access token returned', function () {",
                  "  pm.expect(body.access_token).to.be.a('string').and.not.empty;",
                  "});",
                  "pm.collectionVariables.set('accessToken', body.access_token);"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "me"]
            },
            "description": "Returns the authenticated user profile using Bearer token."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "var body = pm.response.json();",
                  "pm.test('User payload is valid', function () {",
                  "  pm.expect(body).to.have.property('email');",
                  "  pm.expect(body).to.have.property('id');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Content",
      "item": [
        {
          "name": "List Emails",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}{{apiPrefix}}/emails/?limit={{limit}}&offset={{offset}}",
              "host": ["{{baseUrl}}"],
              "path": ["{{apiPrefix}}", "emails", ""],
              "query": [
                { "key": "limit", "value": "{{limit}}" },
                { "key": "offset", "value": "{{offset}}" }
              ]
            },
            "description": "Returns paginated email-like items for the authenticated user."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "var body = pm.response.json();",
                  "pm.test('Paginated response fields present', function () {",
                  "  pm.expect(body).to.have.property('items');",
                  "  pm.expect(body).to.have.property('total');",
                  "  pm.expect(body).to.have.property('limit');",
                  "  pm.expect(body).to.have.property('offset');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "List Documents",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}{{apiPrefix}}/documents/?limit={{limit}}&offset={{offset}}",
              "host": ["{{baseUrl}}"],
              "path": ["{{apiPrefix}}", "documents", ""],
              "query": [
                { "key": "limit", "value": "{{limit}}" },
                { "key": "offset", "value": "{{offset}}" }
              ]
            },
            "description": "Returns paginated document-like items for the authenticated user."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "var body = pm.response.json();",
                  "pm.test('Response contains items array', function () {",
                  "  pm.expect(body.items).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Semantic Search",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}{{apiPrefix}}/search/?q={{searchQuery}}&top_k=10&type_filter={{typeFilter}}",
              "host": ["{{baseUrl}}"],
              "path": ["{{apiPrefix}}", "search", ""],
              "query": [
                { "key": "q", "value": "{{searchQuery}}" },
                { "key": "top_k", "value": "10" },
                { "key": "type_filter", "value": "{{typeFilter}}" }
              ]
            },
            "description": "Runs semantic-style search over user-scoped items and returns ranked results."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "var body = pm.response.json();",
                  "pm.test('Search response contract is valid', function () {",
                  "  pm.expect(body).to.have.property('query');",
                  "  pm.expect(body).to.have.property('results');",
                  "  pm.expect(body).to.have.property('count');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Developer",
      "item": [
        {
          "name": "Create API Key",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"postman-key\",\n  \"allowed_channels\": [\"telegram\"],\n  \"agent_type\": \"openclaw\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}{{apiPrefix}}/developer/api-keys",
              "host": ["{{baseUrl}}"],
              "path": ["{{apiPrefix}}", "developer", "api-keys"]
            },
            "description": "Creates a developer API key and stores the raw key and id into collection variables for chained testing."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', function () { pm.response.to.have.status(201); });",
                  "var body = pm.response.json();",
                  "pm.test('API key payload is valid', function () {",
                  "  pm.expect(body).to.have.property('id');",
                  "  pm.expect(body).to.have.property('api_key');",
                  "  pm.expect(body.api_key).to.match(/^pk_live_/);",
                  "});",
                  "pm.collectionVariables.set('apiKeyId', body.id);",
                  "pm.collectionVariables.set('developerApiKey', body.api_key);"
                ]
              }
            }
          ]
        },
        {
          "name": "List API Keys",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}{{apiPrefix}}/developer/api-keys",
              "host": ["{{baseUrl}}"],
              "path": ["{{apiPrefix}}", "developer", "api-keys"]
            },
            "description": "Lists all API keys for the authenticated user, newest first."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "var body = pm.response.json();",
                  "pm.test('Response is an array', function () { pm.expect(body).to.be.an('array'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Revoke API Key",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}{{apiPrefix}}/developer/api-keys/{{apiKeyId}}/revoke",
              "host": ["{{baseUrl}}"],
              "path": [
                "{{apiPrefix}}",
                "developer",
                "api-keys",
                "{{apiKeyId}}",
                "revoke"
              ]
            },
            "description": "Revokes the selected API key by id. Requires apiKeyId variable from Create API Key request."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (!pm.collectionVariables.get('apiKeyId')) {",
                  "  throw new Error('apiKeyId is empty. Run Create API Key first.');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "var body = pm.response.json();",
                  "pm.test('Key is revoked', function () {",
                  "  pm.expect(body).to.have.property('revoked_at');",
                  "  pm.expect(body.revoked_at).to.not.eql(null);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
